# .env

# 1. The URL for your backend exposed by Ngrok
# Used by vite.config.js to setup the proxy locally
VITE_NGROK_URL=https://duple-registered-maricruz.ngrok-free.dev

# 2. The Base URL for API calls
# For local development, we leave this empty so Axios uses '/api' (which triggers the proxy)
# For Vercel, you will set this to your Ngrok URL in the Vercel Dashboard
VITE_API_BASE_URL=